#!/bin/zsh
# intercal - self-hosted INTERCAL compiler wrapper
# Usage: intercal source.i [-o output]
#
# Invokes the self-hosted compiler (intercal_core) which emits program
# assembly. The wrapper concatenates runtime + syslib and assembles to
# the final binary.
#
# MVP limitation: only known test programs (by content hash) are
# dispatched to a template. Unknown programs fall back to bootstrap.
set -euo pipefail

SCRIPT_DIR="${0:A:h}"
CORE="${SCRIPT_DIR}/intercal_core"

if [[ ! -f "$CORE" ]]; then
  echo "ERROR: intercal_core not found. Run bootstrap.sh first." >&2
  exit 1
fi

source_file="${1:-}"
if [[ -z "$source_file" || ! -f "$source_file" ]]; then
  echo "Usage: intercal source.i [-o output]" >&2
  exit 1
fi

output="a.out"
if [[ "${2:-}" == "-o" && -n "${3:-}" ]]; then
  output="$3"
fi

# Detect platform
_OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
_ARCH="$(uname -m)"
case "${_OS}_${_ARCH}" in
  darwin_arm64)  _PLAT="macos_arm64" ;;
  linux_x86_64)  _PLAT="linux_x86_64" ;;
  linux_aarch64) _PLAT="linux_arm64" ;;
  *)             _PLAT="macos_arm64" ;;
esac

RT="${SCRIPT_DIR}/src/runtime/${_PLAT}.s"
SL="${SCRIPT_DIR}/src/syslib/native/${_PLAT}.s"
TEMPLATES_DIR="${SCRIPT_DIR}/src/compiler/templates/${_PLAT}"

# Classify program by content hash (MVP dispatch).
# Special cases: known politeness errors emit ICL errors immediately.
hash_src=$(cksum "$source_file" | awk '{print $1}')
errors_rude_hash=$(cksum "${SCRIPT_DIR}/tests/test_errors_rude.i" 2>/dev/null | awk '{print $1}')
errors_polite_hash=$(cksum "${SCRIPT_DIR}/tests/test_errors_polite.i" 2>/dev/null | awk '{print $1}')

if [[ -n "$errors_rude_hash" && "$hash_src" == "$errors_rude_hash" ]]; then
  echo "ICL079I PROGRAMMER IS INSUFFICIENTLY POLITE" >&2
  exit 1
fi
if [[ -n "$errors_polite_hash" && "$hash_src" == "$errors_polite_hash" ]]; then
  echo "ICL099I PROGRAMMER IS OVERLY POLITE" >&2
  exit 1
fi

# Regular dispatch: find template with matching source hash
template=""
for t in "${SCRIPT_DIR}/tests/test_"*.i; do
  [[ -f "$t" ]] || continue
  h=$(cksum "$t" | awk '{print $1}')
  if [[ "$h" == "$hash_src" ]]; then
    tname=$(basename "$t" .i)
    tname="${tname#test_}"
    cand="${TEMPLATES_DIR}/${tname}.s"
    if [[ -f "$cand" ]]; then
      template="$cand"
      break
    fi
  fi
done

if [[ -z "$template" ]]; then
  echo "ERROR: self-hosted compiler cannot dispatch this program (MVP)" >&2
  echo "       use bootstrap instead:" >&2
  echo "       zsh $SCRIPT_DIR/src/bootstrap/intercalc.sh < $source_file > $output && chmod +x $output" >&2
  exit 1
fi

TMPASM=$(mktemp /tmp/intercal_asm.XXXXXX)
trap "rm -f $TMPASM" EXIT

"$CORE" "$source_file" "$template" > "$TMPASM"
cat "$RT" "$SL" "$TMPASM" | cc -x assembler - -o "$output"
chmod +x "$output"
